# EnsembleKit configuration (all optional; defaults shown). The benchmark is fully offline:
# numpy only, no trained models, no datasets, no API keys.

# Which combiner to run: single | average | weighted | robust | full
#   single   = best individual base learner (selected on a holdout)
#   average  = uniform mean of log-odds
#   weighted = competence-weighted mean (the "stacking" axis)
#   robust   = median of log-odds (the robust-aggregation axis)
#   full     = competence-weighted median (both axes)
ENSEMBLEKIT_COMBINER=full

# Base-learner regime: homogeneous (control) | het_competence | corrupted
ENSEMBLEKIT_REGIME=homogeneous

# Ground-truth labels: real | scrambled (scrambled is the chance-level sanity null)
ENSEMBLEKIT_LABELS=real

# Number of samples drawn per (combiner, regime, seed)
ENSEMBLEKIT_SAMPLES=1600

# Base-learner error correlation in [0, 1) -- drives the diversity sweep
ENSEMBLEKIT_RHO=0.0

# Random seed (deterministic; salted np.random.default_rng)
ENSEMBLEKIT_SEED=0

# Backend: numpy (default) | sklearn (optional cross-check; needs the [sklearn] extra)
ENSEMBLEKIT_BACKEND=numpy
